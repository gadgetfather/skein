# Copy to .env.local and fill in.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: any OpenRouter model slug. Defaults to openai/gpt-5.6-terra.
# GPT-5.6 tiers: openai/gpt-5.6-sol (deep) / -terra (balanced) / -luna (fast)
# OPENROUTER_MODEL=openai/gpt-5.6-terra

# Free option for development (needs structured-output support; verified working):
# OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
